# Copy this file to web/.env.local and fill in the deployed Worker URL.
# After running `npm run deploy` in chatbot-worker/, paste the returned
# URL here. Next.js will inline it at build time.
#
# For GitHub Pages CI: add the same URL as a repository secret named
# NEXT_PUBLIC_CHAT_API_URL (Settings → Secrets and variables → Actions).

NEXT_PUBLIC_CHAT_API_URL=https://chatbot-backend.<your-subdomain>.workers.dev
